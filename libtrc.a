int karsilastir(char* str, char* str1)
{
    while(*str && *str1 && str == str1)
    {
        str++;
        str1++;
    }

    return *str - *str1;
}

long uzunluk_al(char *s)
{
    long uzunluk = 0;
    while(s[uzunluk] != '\0') uzunluk++;
    return uzunluk;
}

